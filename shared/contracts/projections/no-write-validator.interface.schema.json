{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numberninjatees.github.io/contracts/projections/no-write-validator.interface.schema.json",
  "title": "Studio OS No-Write Validator Interface",
  "description": "Validator result interface for structural inspection without runtime, projection, dashboard, provider, deployment, or credential mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "validatorId",
    "mode",
    "evaluatedAt",
    "writeBoundary",
    "inspectionScope",
    "result"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "validatorId": {
      "type": "string",
      "pattern": "^validator-[a-z0-9-]{8,80}$"
    },
    "mode": {
      "type": "string",
      "const": "no-write-structural-inspection"
    },
    "evaluatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "writeBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writesAllowed",
        "runtimeMutationAllowed",
        "projectionMutationAllowed",
        "dashboardMutationAllowed",
        "returnsInMemoryOnly"
      ],
      "properties": {
        "writesAllowed": {
          "type": "boolean",
          "const": false
        },
        "runtimeMutationAllowed": {
          "type": "boolean",
          "const": false
        },
        "projectionMutationAllowed": {
          "type": "boolean",
          "const": false
        },
        "dashboardMutationAllowed": {
          "type": "boolean",
          "const": false
        },
        "returnsInMemoryOnly": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "inspectionScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structureOnly",
        "businessRulesEvaluated",
        "runtimeTruthModified"
      ],
      "properties": {
        "structureOnly": {
          "type": "boolean",
          "const": true
        },
        "businessRulesEvaluated": {
          "type": "boolean",
          "const": false
        },
        "runtimeTruthModified": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "checks"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail"
          ]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status",
              "message"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 3,
                "maxLength": 120
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "warning",
                  "fail"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 3,
                "maxLength": 240
              }
            }
          }
        }
      }
    }
  }
}
