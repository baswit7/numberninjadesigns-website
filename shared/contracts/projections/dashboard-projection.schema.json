{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numberninjatees.github.io/contracts/projections/dashboard-projection.schema.json",
  "title": "Studio OS Dashboard Projection",
  "description": "Read-only derived projection for passive dashboard consumption. Runtime evidence remains the source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectionId",
    "generatedAt",
    "generatedBy",
    "authority",
    "sourceEvidence",
    "validationSummary",
    "boundarySummary",
    "staleness",
    "display"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "projectionId": {
      "type": "string",
      "pattern": "^dashboard-projection-[a-z0-9-]{8,80}$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "type": "string",
      "const": "services/dashboard-adapter"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeTruthOwner",
        "projectionProducer",
        "dashboardRole",
        "projectionIsAuthoritative"
      ],
      "properties": {
        "runtimeTruthOwner": {
          "type": "string",
          "const": "runtime"
        },
        "projectionProducer": {
          "type": "string",
          "const": "services/dashboard-adapter"
        },
        "dashboardRole": {
          "type": "string",
          "const": "passive-visual-consumer"
        },
        "projectionIsAuthoritative": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "sourceEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceId",
          "sourceKind",
          "sourcePath",
          "sourceStatus",
          "observedAt"
        ],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120
          },
          "sourceKind": {
            "type": "string",
            "enum": [
              "governance-document",
              "runtime-report",
              "readiness-report",
              "validation-report",
              "health-output"
            ]
          },
          "sourcePath": {
            "type": "string",
            "minLength": 3,
            "maxLength": 240
          },
          "sourceStatus": {
            "type": "string",
            "enum": [
              "pass",
              "warning",
              "fail",
              "missing",
              "unknown"
            ]
          },
          "observedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "validationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overallStatus",
        "validatorResults"
      ],
      "properties": {
        "overallStatus": {
          "type": "string",
          "enum": [
            "pass",
            "warning",
            "fail",
            "unknown"
          ]
        },
        "validatorResults": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "validatorId",
              "status",
              "reportPath"
            ],
            "properties": {
              "validatorId": {
                "type": "string",
                "minLength": 3,
                "maxLength": 120
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "warning",
                  "fail",
                  "unknown"
                ]
              },
              "reportPath": {
                "type": "string",
                "minLength": 3,
                "maxLength": 240
              }
            }
          }
        }
      }
    },
    "boundarySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writesAllowed",
        "runtimeMutationAllowed",
        "projectionMutationAllowed",
        "executionEnabled",
        "providerCallsAllowed",
        "deploymentAllowed",
        "secretAccessAllowed",
        "dashboardMutationAllowed"
      ],
      "properties": {
        "writesAllowed": {
          "type": "boolean",
          "const": false
        },
        "runtimeMutationAllowed": {
          "type": "boolean",
          "const": false
        },
        "projectionMutationAllowed": {
          "type": "boolean",
          "const": false
        },
        "executionEnabled": {
          "type": "boolean",
          "const": false
        },
        "providerCallsAllowed": {
          "type": "boolean",
          "const": false
        },
        "deploymentAllowed": {
          "type": "boolean",
          "const": false
        },
        "secretAccessAllowed": {
          "type": "boolean",
          "const": false
        },
        "dashboardMutationAllowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "staleness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "lastSourceObservedAt",
        "staleReason"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "unknown"
          ]
        },
        "lastSourceObservedAt": {
          "type": "string",
          "format": "date-time"
        },
        "staleReason": {
          "type": "string",
          "minLength": 0,
          "maxLength": 240
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "labels",
        "sections"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "not executable",
              "readiness evidence only",
              "provider calls disabled",
              "deployment disabled",
              "secret access disabled",
              "runtime is source of truth",
              "adapter produced projection",
              "dashboard read only"
            ]
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sectionId",
              "heading",
              "sourceIds"
            ],
            "properties": {
              "sectionId": {
                "type": "string",
                "pattern": "^[a-z0-9-]{3,80}$"
              },
              "heading": {
                "type": "string",
                "minLength": 3,
                "maxLength": 120
              },
              "sourceIds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 3,
                  "maxLength": 120
                }
              }
            }
          }
        }
      }
    }
  }
}
