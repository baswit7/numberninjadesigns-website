{
  "schemaVersion": "1.0.0",
  "contractFamily": "studio-os-dashboard-projections",
  "purpose": "Define read-only projection artifacts for passive dashboard consumption.",
  "runtimeTruthOwner": "runtime",
  "projectionProducer": "services/dashboard-adapter",
  "dashboardRole": "passive-visual-consumer",
  "projectionAuthority": "derived-only",
  "contracts": [
    {
      "contractId": "dashboard-projection",
      "path": "shared/contracts/projections/dashboard-projection.schema.json",
      "outputKind": "read-only-derived-projection"
    },
    {
      "contractId": "no-write-validator-interface",
      "path": "shared/contracts/projections/no-write-validator.interface.schema.json",
      "outputKind": "in-memory-structural-validation-result"
    }
  ],
  "boundary": {
    "writesAllowed": false,
    "runtimeMutationAllowed": false,
    "projectionMutationAllowed": false,
    "dashboardMutationAllowed": false,
    "executionEnabled": false,
    "providerCallsAllowed": false,
    "deploymentAllowed": false,
    "secretAccessAllowed": false
  },
  "allowedProjectionContent": [
    "source identities",
    "source paths",
    "validation status summaries",
    "boundary status summaries",
    "staleness metadata",
    "display labels",
    "links back to source evidence"
  ],
  "prohibitedProjectionContent": [
    "commands",
    "script paths",
    "external endpoints",
    "credential material",
    "execution payloads",
    "deployment payloads",
    "approval write payloads",
    "scheduler configuration",
    "queue configuration",
    "provider invocation details"
  ]
}
