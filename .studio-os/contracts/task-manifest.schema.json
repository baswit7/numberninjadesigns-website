{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.numberninjadesigns.com/.studio-os/contracts/task-manifest.schema.json",
  "title": "Studio OS Task Manifest",
  "description": "Fail-closed contract for work delegated by the central supervisor.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "project",
    "repository",
    "branch",
    "taskType",
    "objective",
    "knownEvidence",
    "relevantPaths",
    "allowedReadPaths",
    "allowedWritePaths",
    "prohibitedPaths",
    "dependencies",
    "acceptanceCriteria",
    "validationCommands",
    "tokenBudget",
    "maximumIterations",
    "assignedAgent",
    "outputSchema"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "taskId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "project": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "repository": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "taskType": {
      "type": "string",
      "enum": [
        "small-bug",
        "complex-bug",
        "local-ui",
        "module-feature",
        "cross-module",
        "tests",
        "release",
        "docs",
        "architecture"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "knownEvidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      },
      "uniqueItems": true
    },
    "relevantPaths": {
      "$ref": "#/$defs/pathList"
    },
    "allowedReadPaths": {
      "$ref": "#/$defs/pathList"
    },
    "allowedWritePaths": {
      "$ref": "#/$defs/pathList"
    },
    "prohibitedPaths": {
      "allOf": [
        {
          "$ref": "#/$defs/pathList"
        },
        {
          "contains": {
            "type": "string",
            "pattern": "(^|/)generated(/|$)"
          }
        },
        {
          "contains": {
            "type": "string",
            "pattern": "(^|/)cache(/|$)"
          }
        },
        {
          "contains": {
            "type": "string",
            "pattern": "(^|/)secrets(/|$)"
          }
        },
        {
          "contains": {
            "type": "string",
            "pattern": "(^|/)\\.env(?:\\..*)?$"
          }
        }
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "uniqueItems": true
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "uniqueItems": true
    },
    "validationCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "tokenBudget": {
      "type": "integer",
      "minimum": 1
    },
    "maximumIterations": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "description": "Initial attempt plus no more than one retry."
    },
    "assignedAgent": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$"
    },
    "outputSchema": {
      "type": "string",
      "const": ".studio-os/contracts/agent-result.schema.json"
    }
  },
  "$defs": {
    "pathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500,
        "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
      },
      "uniqueItems": true
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "observation"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "observation": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        }
      }
    }
  }
}
